{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MedPanel Patient Profile",
  "description": "FHIR-aligned patient profile for multi-specialist health exploration. MVP + comprehensive fields.",
  "type": "object",
  "required": ["demographics", "chief_complaint"],
  "properties": {
    "profile_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique patient profile identifier"
    },
    "profile_version": {
      "type": "integer",
      "description": "Incremented on every profile update. Consultations reference specific versions."
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },

    "demographics": {
      "type": "object",
      "required": ["age", "sex"],
      "properties": {
        "age": { "type": "integer", "minimum": 0, "maximum": 120 },
        "sex": { "type": "string", "enum": ["male", "female", "other"] },
        "height_cm": { "type": "number" },
        "weight_kg": { "type": "number" },
        "bmi": { "type": "number", "description": "Auto-calculated from height/weight" },
        "body_fat_percentage": { "type": "number" },
        "ethnicity": { "type": "string", "description": "Relevant for pharmacogenomics and disease prevalence" },
        "country": { "type": "string", "description": "Affects drug availability, guidelines, reference ranges" }
      }
    },

    "chief_complaint": {
      "type": "string",
      "description": "The user's primary question or health concern in free text"
    },

    "conditions": {
      "type": "array",
      "description": "Active and resolved diagnoses",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "icd10_code": { "type": "string", "pattern": "^[A-Z][0-9]{2}(\\.[0-9]{1,4})?$" },
          "snomed_code": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "resolved", "remission", "suspected"] },
          "onset_date": { "type": "string", "format": "date" },
          "severity": { "type": "string", "enum": ["mild", "moderate", "severe"] },
          "notes": { "type": "string" }
        }
      }
    },

    "medications": {
      "type": "array",
      "description": "Current and recent medications including supplements",
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": { "type": "string" },
          "rxnorm_cui": { "type": "string" },
          "type": { "type": "string", "enum": ["prescription", "otc", "supplement", "prn"] },
          "dose": { "type": "string", "description": "e.g., '500mg'" },
          "frequency": { "type": "string", "description": "e.g., 'twice daily', 'as needed'" },
          "route": { "type": "string", "enum": ["oral", "sublingual", "topical", "injection_im", "injection_subq", "injection_iv", "inhaled", "rectal", "other"] },
          "status": { "type": "string", "enum": ["active", "discontinued", "planned"] },
          "start_date": { "type": "string", "format": "date" },
          "end_date": { "type": "string", "format": "date" },
          "prescribing_reason": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },

    "allergies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["substance", "type"],
        "properties": {
          "substance": { "type": "string" },
          "type": { "type": "string", "enum": ["allergy", "intolerance", "sensitivity"] },
          "severity": { "type": "string", "enum": ["mild", "moderate", "severe", "life_threatening"] },
          "reaction": { "type": "string", "description": "e.g., 'hives', 'anaphylaxis', 'GI distress'" },
          "ige_level": { "type": "number", "description": "If tested, kU/L" },
          "verified": { "type": "boolean", "description": "Clinically confirmed vs self-reported" }
        }
      }
    },

    "vitals": {
      "type": "object",
      "description": "Most recent vital signs",
      "properties": {
        "blood_pressure_systolic": { "type": "integer" },
        "blood_pressure_diastolic": { "type": "integer" },
        "bp_measurement_context": { "type": "string", "enum": ["home_morning", "home_evening", "clinic", "14_day_average"] },
        "heart_rate_resting": { "type": "integer" },
        "heart_rate_context": { "type": "string", "description": "e.g., 'morning resting', 'daytime average'" },
        "respiratory_rate": { "type": "integer" },
        "temperature_c": { "type": "number" },
        "spo2": { "type": "integer" },
        "measured_at": { "type": "string", "format": "date-time" }
      }
    },

    "lab_results": {
      "type": "array",
      "description": "Lab results with LOINC codes, units, reference ranges, and interpretation",
      "items": {
        "type": "object",
        "required": ["name", "value", "unit", "date"],
        "properties": {
          "name": { "type": "string" },
          "loinc_code": { "type": "string" },
          "value": { "type": "number" },
          "value_string": { "type": "string", "description": "For non-numeric results (e.g., 'positive', '<0.35')" },
          "unit": { "type": "string", "description": "UCUM standard (e.g., 'mg/dL', 'nmol/L')" },
          "reference_range_low": { "type": "number" },
          "reference_range_high": { "type": "number" },
          "interpretation": { "type": "string", "enum": ["normal", "high", "low", "critical_high", "critical_low"] },
          "date": { "type": "string", "format": "date" },
          "lab_name": { "type": "string", "description": "Which lab performed the test" },
          "notes": { "type": "string" }
        }
      }
    },

    "family_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "relationship": { "type": "string", "enum": ["father", "mother", "sibling", "grandparent_paternal", "grandparent_maternal", "child", "other"] },
          "condition": { "type": "string" },
          "age_of_onset": { "type": "integer" },
          "deceased": { "type": "boolean" },
          "age_at_death": { "type": "integer" },
          "cause_of_death": { "type": "string" }
        }
      }
    },

    "surgical_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "procedure": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "notes": { "type": "string", "description": "e.g., 'metal plates still in place'" }
        }
      }
    },

    "social_history": {
      "type": "object",
      "properties": {
        "smoking": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["never", "former", "current"] },
            "quit_date": { "type": "string", "format": "date" },
            "pack_years": { "type": "number" }
          }
        },
        "alcohol": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["never", "former", "occasional", "moderate", "heavy"] },
            "quit_date": { "type": "string", "format": "date" }
          }
        },
        "substance_use": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "substance": { "type": "string" },
              "status": { "type": "string", "enum": ["never", "former", "current"] },
              "quit_date": { "type": "string", "format": "date" },
              "duration": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        },
        "exercise": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "description": "e.g., 'resistance 4x/week + Zone 2 daily'" },
            "frequency_per_week": { "type": "integer" },
            "duration_minutes": { "type": "integer" }
          }
        },
        "diet": {
          "type": "object",
          "properties": {
            "description": { "type": "string" },
            "restrictions": { "type": "array", "items": { "type": "string" } },
            "protein_g_per_day": { "type": "integer" },
            "calories_per_day": { "type": "integer" }
          }
        },
        "sleep": {
          "type": "object",
          "properties": {
            "hours_per_night": { "type": "number" },
            "bedtime": { "type": "string", "description": "e.g., '11 PM' or '12-3 AM variable'" },
            "wake_time": { "type": "string" },
            "quality": { "type": "string", "enum": ["good", "fair", "poor"] },
            "issues": { "type": "array", "items": { "type": "string" } }
          }
        },
        "occupation": { "type": "string" },
        "stress_level": { "type": "string", "enum": ["low", "moderate", "high", "severe"] },
        "living_situation": { "type": "string" }
      }
    },

    "mental_health": {
      "type": "object",
      "properties": {
        "diagnoses": { "type": "array", "items": { "type": "string" } },
        "trauma_history": { "type": "string", "description": "Brief summary, user-reported" },
        "current_therapy": { "type": "string", "enum": ["none", "planned", "active"] },
        "therapy_type": { "type": "string" },
        "phq9_score": { "type": "integer" },
        "gad7_score": { "type": "integer" },
        "substance_use_recovery": {
          "type": "object",
          "properties": {
            "in_recovery": { "type": "boolean" },
            "months_sober": { "type": "integer" },
            "substances_recovered_from": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },

    "goals": {
      "type": "array",
      "description": "What the user is trying to achieve",
      "items": {
        "type": "string"
      }
    },

    "completeness_score": {
      "type": "object",
      "description": "Auto-calculated profile completeness",
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "missing_mvp_fields": { "type": "array", "items": { "type": "string" } },
        "missing_recommended_fields": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
